# TalentFlow FastAPI 本地开发配置模板。
# 在 backend 目录执行：Copy-Item ".env.example" ".env"
# 复制后只填写 OPENAI_API_KEY；真实 Key 只能保存在本地 backend/.env。

# 基础应用配置
APP_ENV=development
APP_NAME=TalentFlow
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# 数据库配置
DATABASE_URL=postgresql+psycopg://talentflow:talentflow_dev_password_change_me@localhost:5433/talentflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=talentflow
POSTGRES_PASSWORD=talentflow_dev_password_change_me
POSTGRES_DB=talentflow

# 认证配置
JWT_SECRET_KEY=talentflow_local_dev_jwt_secret_not_for_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# 跨域配置
CORS_ORIGINS=http://localhost:5173

# LLM / Agent 配置
LLM_ENABLED=true
LLM_PROVIDER=openai_compatible
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.2

OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_KEY=
OPENAI_MODEL=你的豆包Seed-2.1-Pro模型ID或推理接入点ID

# 本地文件与 RAG 配置
RAG_ENABLED=true
RAG_AUTO_INITIALIZE=true
CHROMA_PERSIST_DIR=../data/runtime/chroma
CHROMA_COLLECTION_NAME=talentflow_policies
POLICY_DATA_DIR=../data/policies

EMBEDDING_PROVIDER=volcengine_multimodal
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=doubao-embedding-vision-251215
EMBEDDING_BATCH_SIZE=1

RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.2
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
UPLOAD_DIR=../data/runtime/uploads
REPORT_DIR=../data/runtime/reports
