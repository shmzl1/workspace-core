# TalentFlow FastAPI 本地开发配置模板。
# 每位成员都应复制为 `backend/.env`，并填写自己的本地值。
# `OPENAI_API_KEY` 只能存在于本地 `backend/.env`，不得提交到仓库。
# `LLM_ENABLED=false` 允许没有模型 API Key 时先开发普通业务和前端。

# 基础应用配置
APP_ENV=development
APP_NAME=TalentFlow
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# 数据库配置
DATABASE_URL=postgresql+psycopg://talentflow:talentflow_dev_password_change_me@localhost:5433/talentflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=talentflow
POSTGRES_PASSWORD=talentflow_dev_password_change_me
POSTGRES_DB=talentflow

# 认证配置
JWT_SECRET_KEY=replace_with_a_local_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# 跨域配置
CORS_ORIGINS=http://localhost:5173

# LLM / Agent 配置
LLM_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.2
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# 本地文件与 RAG 配置
RAG_ENABLED=false
RAG_AUTO_INITIALIZE=false
CHROMA_PERSIST_DIR=../data/runtime/chroma
CHROMA_COLLECTION_NAME=talentflow_policies
POLICY_DATA_DIR=../data/policies
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_MODEL=
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.2
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
UPLOAD_DIR=../data/runtime/uploads
REPORT_DIR=../data/runtime/reports

# 请手动将新增键同步到已有 backend/.env，不要直接覆盖成员本地配置。
# LLM_ENABLED=false、RAG_ENABLED=false 且模型字段留空时，确定性业务继续运行。
