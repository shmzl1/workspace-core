+from concurrent.futures import ThreadPoolExecutor
+
+import pytest
+
+from app.rag.ingestion.contracts import LoadedKnowledgeDocument
+from app.rag.ingestion.splitter import StructuredKnowledgeSplitter
+from app.rag.schemas import PolicyDocumentMetadata
+
+
+@pytest.mark.concurrency
+def test_shared_splitter_is_deterministic_under_light_concurrency() -> None:
+    splitter = StructuredKnowledgeSplitter(chunk_size=64, chunk_overlap=8)
+    source = LoadedKnowledgeDocument(
+        metadata=PolicyDocumentMetadata(
+            source_id="concurrency-policy",
+            title="并发测试制度",
+            document_type="POLICY",
+        ),
+        content=("# 招聘原则\n\n必须保留人工最终决定。\n\n" * 20),
+    )
+
+    def split_once(_: int) -> list[dict[str, object]]:
+        return [chunk.model_dump(mode="json") for chunk in splitter.split(source)]
+
+    baseline = split_once(0)
+    with ThreadPoolExecutor(max_workers=8) as executor:
+        results = list(executor.map(split_once, range(64)))
+
+    assert baseline
+    assert all(result == baseline for result in results)
